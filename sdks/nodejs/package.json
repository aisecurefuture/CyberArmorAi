    "./providers/anthropic": "./dist/cjs/providers/anthropic.js",
    "./providers/google": "./dist/cjs/providers/google.js",
    "./providers/amazon": "./dist/cjs/providers/amazon.js",
    "./providers/microsoft": "./dist/cjs/providers/microsoft.js",
    "./providers/xai": "./dist/cjs/providers/xai.js",
    "./providers/meta": "./dist/cjs/providers/meta.js",
    "./providers/perplexity": "./dist/cjs/providers/perplexity.js",
    "./frameworks/langchain": "./dist/cjs/frameworks/langchain.js",
    "./frameworks/vercelAI": "./dist/cjs/frameworks/vercelAI.js",
    "./frameworks/llamaindex": "./dist/cjs/frameworks/llamaindex.js",
    "./middleware/express": "./dist/cjs/middleware/express.js",
    "./middleware/nextjs": "./dist/cjs/middleware/nextjs.js"
