# CyberArmor AI Identity Control Plane — C/C++ SDK
# pkg-config file
#
# Generated by CMake from cyberarmor.pc.in
# Install location: ${libdir}/pkgconfig/cyberarmor.pc
#
# Usage:
#   pkg-config --cflags cyberarmor
#   pkg-config --libs   cyberarmor
#   cc myapp.c $(pkg-config --cflags --libs cyberarmor) -o myapp

prefix=@CA_PC_PREFIX@
exec_prefix=@CA_PC_EXEC_PREFIX@
libdir=@CA_PC_LIBDIR@
includedir=@CA_PC_INCLUDEDIR@

Name:        libcyberarmor
Description: @CA_PC_DESCRIPTION@
Version:     @CA_PC_VERSION@
URL:         https://cyberarmor.ai

Requires:    libcurl
Libs:        -L${libdir} -lcyberarmor
Libs.private: -lcurl
Cflags:      -I${includedir}
