{
  "name": "cyberarmor-cursor",
  "displayName": "CyberArmor Protect for Cursor",
  "description": "Enterprise AI security — monitors AI code generation, DLP scanning, policy enforcement",
  "version": "1.0.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "cyberarmor-cursor.scanFile", "title": "CyberArmor: Scan Current File" },
      { "command": "cyberarmor-cursor.toggleMonitoring", "title": "CyberArmor: Toggle Monitoring" }
    ],
    "configuration": {
      "title": "CyberArmor Protect",
      "properties": {
        "cyberarmor.controlPlaneUrl": { "type": "string", "default": "http://localhost:8000" },
        "cyberarmor.apiKey": { "type": "string", "default": "", "description": "Plaintext API key or precomputed PQC credential value" },
        "cyberarmor.tenantId": { "type": "string", "default": "default" }
      }
    }
  },
  "scripts": { "compile": "tsc -p ./", "watch": "tsc -watch -p ./" },
  "devDependencies": { "@types/vscode": "^1.85.0", "typescript": "^5.3.0" }
}
