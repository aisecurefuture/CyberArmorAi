{
  "name": "cyberarmor-kiro",
  "displayName": "CyberArmor Protect for Kiro",
  "description": "Enterprise AI security for Kiro IDE — DLP scanning, AI code monitoring, policy enforcement",
  "version": "1.0.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "cyberarmor-kiro.scanFile", "title": "CyberArmor: Scan Current File" },
      { "command": "cyberarmor-kiro.redactFindings", "title": "CyberArmor: Redact Findings" },
      { "command": "cyberarmor-kiro.redeemBootstrapToken", "title": "CyberArmor: Redeem Bootstrap Token" }
    ],
    "configuration": {
      "title": "CyberArmor Protect",
      "properties": {
        "cyberarmor.controlPlaneUrl": { "type": "string", "default": "http://localhost:8000" },
        "cyberarmor.apiKey": { "type": "string", "default": "", "description": "Plaintext API key or precomputed PQC credential value" },
        "cyberarmor.bootstrapToken": { "type": "string", "default": "", "description": "One-time bootstrap token for enrollment" },
        "cyberarmor.tenantId": { "type": "string", "default": "default" },
        "cyberarmor.enforcementMode": {
          "type": "string",
          "default": "monitor",
          "enum": ["monitor", "warn", "block", "redact", "redact-secrets", "redact-pii", "redact-pci", "redact-nacha", "redact-npi", "redact-nonpublic"],
          "description": "How CyberArmor responds to sensitive findings. Redaction modes rewrite matching content before it leaves the editor."
        }
      }
    }
  },
  "scripts": { "compile": "tsc -p ./", "watch": "tsc -watch -p ./" },
  "devDependencies": { "@types/vscode": "^1.85.0", "typescript": "^5.3.0" }
}
