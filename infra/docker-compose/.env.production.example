# CyberArmor production/demo server env example
# Copy to a root-owned file on the server, for example:
#   /etc/cyberarmor/demo.env
#
# Recommended permissions:
#   chown root:root /etc/cyberarmor/demo.env
#   chmod 600 /etc/cyberarmor/demo.env
#
# Do not commit real values.

# Public DNS / URLs
LE_EMAIL=ops@cyberarmor.ai
APP_DOMAIN=app.cyberarmor.ai
ADMIN_DOMAIN=admin.cyberarmor.ai
MARKETING_DOMAIN=cyberarmor.ai
WWW_MARKETING_DOMAIN=www.cyberarmor.ai
DOCS_DOMAIN=docs.cyberarmor.ai
SUPPORT_DOMAIN=support.cyberarmor.ai
CUSTOMER_PORTAL_PUBLIC_URL=https://app.cyberarmor.ai

# Core auth secrets
CYBERARMOR_API_SECRET=replace-with-strong-random-value
CYBERARMOR_JWT_SECRET=replace-with-strong-random-value
POLICY_API_SECRET=replace-with-strong-random-value
POLICY_API_KEY=replace-with-strong-random-value
DETECTION_API_SECRET=replace-with-strong-random-value
IDENTITY_API_SECRET=replace-with-strong-random-value
SIEM_API_SECRET=replace-with-strong-random-value
COMPLIANCE_API_SECRET=replace-with-strong-random-value
PROXY_AGENT_API_SECRET=replace-with-strong-random-value
RESPONSE_API_SECRET=replace-with-strong-random-value
AGENT_IDENTITY_API_SECRET=replace-with-strong-random-value
AGENT_IDENTITY_JWT_SECRET=replace-with-strong-random-value
ROUTER_API_SECRET=replace-with-strong-random-value
ROUTER_ENCRYPTION_KEY=replace-with-64-hex-characters
AUDIT_API_SECRET=replace-with-strong-random-value
TELEMETRY_API_KEY=replace-with-strong-random-value
INTEGRATION_CONTROL_API_SECRET=replace-with-strong-random-value
SECRETS_SERVICE_API_SECRET=replace-with-strong-random-value
CYBERARMOR_ENV_FILE=.env.production
HOST_BIND=127.0.0.1
CADDY_DNS_1=1.1.1.1
CADDY_DNS_2=8.8.8.8

OPENBAO_DEV_ROOT_TOKEN=replace-with-strong-random-value

# Dashboard / customer auth
ADMIN_DASHBOARD_ALLOWED_EMAILS=admin@cyberarmor.ai
ADMIN_DASHBOARD_SESSION_SECRET=replace-with-strong-random-value
ADMIN_DASHBOARD_AUTH_DEV_CODE_ECHO=false
ADMIN_DASHBOARD_CODE_TTL_SECONDS=600
ADMIN_DASHBOARD_SESSION_TTL_SECONDS=28800
ADMIN_DASHBOARD_MAX_CODE_ATTEMPTS=5
ADMIN_DASHBOARD_COOKIE_SECURE=true
ADMIN_DASHBOARD_SMTP_HOST=smtp.example.com
ADMIN_DASHBOARD_SMTP_PORT=587
ADMIN_DASHBOARD_SMTP_USER=mailer@example.com
ADMIN_DASHBOARD_SMTP_PASSWORD=replace-with-real-smtp-password
ADMIN_DASHBOARD_SMTP_FROM=no-reply@cyberarmor.ai
ADMIN_DASHBOARD_SMTP_TLS=true

CUSTOMER_PORTAL_SESSION_SECRET=replace-with-strong-random-value
CUSTOMER_PORTAL_AUTH_DEV_CODE_ECHO=false
CUSTOMER_PORTAL_CODE_TTL_SECONDS=600
CUSTOMER_PORTAL_SESSION_TTL_SECONDS=28800
CUSTOMER_PORTAL_MAX_CODE_ATTEMPTS=5
CUSTOMER_PORTAL_COOKIE_SECURE=true
CUSTOMER_PORTAL_SMTP_HOST=smtp.example.com
CUSTOMER_PORTAL_SMTP_PORT=587
CUSTOMER_PORTAL_SMTP_USER=mailer@example.com
CUSTOMER_PORTAL_SMTP_PASSWORD=replace-with-real-smtp-password
CUSTOMER_PORTAL_SMTP_FROM=no-reply@cyberarmor.ai
CUSTOMER_PORTAL_SMTP_TLS=true

MARKETING_CONTACT_SMTP_HOST=smtp.example.com
MARKETING_CONTACT_SMTP_PORT=587
MARKETING_CONTACT_SMTP_USER=mailer@example.com
MARKETING_CONTACT_SMTP_PASSWORD=replace-with-real-smtp-password
MARKETING_CONTACT_SMTP_FROM=no-reply@cyberarmor.ai
MARKETING_CONTACT_SMTP_TLS=true
MARKETING_CONTACT_TO=hello@cyberarmor.ai

# Database
POSTGRES_USER=cyberarmor
POSTGRES_PASSWORD=replace-with-strong-random-value
POSTGRES_DB=cyberarmor
DATABASE_URL=postgresql://cyberarmor:replace-with-strong-random-value@postgres:5432/cyberarmor

# Host port bindings
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
OPA_HOST_PORT=8181
OPENBAO_HOST_PORT=8200
POLICY_HOST_PORT=8001
AGENT_IDENTITY_HOST_PORT=8008
AI_ROUTER_HOST_PORT=8009
AUDIT_HOST_PORT=8011
SECRETS_SERVICE_HOST_PORT=8013
CUSTOMER_PORTAL_HOST_PORT=3001
MARKETING_HOST_PORT=3002
DOCS_HOST_PORT=3004

# Secure runtime defaults
CYBERARMOR_ENFORCE_SECURE_SECRETS=true
CYBERARMOR_ALLOW_INSECURE_DEFAULTS=false
CYBERARMOR_ENFORCE_MTLS=false
CYBERARMOR_TLS_CA_FILE=/etc/cyberarmor/tls/ca.crt
CYBERARMOR_TLS_CERT_FILE=/etc/cyberarmor/tls/tls.crt
CYBERARMOR_TLS_KEY_FILE=/etc/cyberarmor/tls/tls.key
CYBERARMOR_ENABLE_NATIVE_TLS_LISTENER=false
CYBERARMOR_REQUIRE_CLIENT_CERT=false
CYBERARMOR_PQC_BACKEND=secrets-service
CYBERARMOR_PQC_AUTH_ENABLED=false
CYBERARMOR_PQC_OUTBOUND_STRICT=false
CYBERARMOR_PQC_ALLOW_PLAINTEXT=true
CYBERARMOR_PQC_REQUIRE_ENCRYPTED=false
CYBERARMOR_PQC_PUBLIC_KEY_CACHE_TTL_SECONDS=300
CYBERARMOR_PQC_PUBLIC_KEY_TIMEOUT_SECONDS=3
CYBERARMOR_PQC_ROTATION_INTERVAL_SECONDS=86400

# Service URLs / secrets backend
CONTROL_PLANE_URL=http://control-plane:8000
POLICY_SERVICE_URL=http://policy:8001
DETECTION_SERVICE_URL=http://detection:8002
AISR_RUNTIME_URL=http://runtime:8000
PROXY_AGENT_URL=http://proxy-agent:8010
AGENT_IDENTITY_URL=http://agent-identity:8008
AI_ROUTER_URL=http://ai-router:8009
AUDIT_URL=http://audit:8011
TELEMETRY_ENDPOINT=http://siem-connector:8005/ingest
COMPLIANCE_URL=http://compliance:8006
INTEGRATION_CONTROL_URL=http://integration-control:8012
SECRETS_SERVICE_URL=http://secrets-service:8013
OPENBAO_ADDR=http://openbao:8200
OPENBAO_NAMESPACE=
OPENBAO_KV_MOUNT=cyberarmor-kv
OPENBAO_TRANSIT_MOUNT=cyberarmor-transit
OPENBAO_TIMEOUT_SECONDS=5
ROUTER_USE_SECRETS_SERVICE=true
ROUTER_REQUIRE_SECRETS_SERVICE=false

# Tenant/runtime defaults
TENANT_ID=default
DEFAULT_PROXY_RUNTIME_MODE=mitm
TENANT_PROXY_MODES={}
TENANT_MODE_CACHE_TTL_SECONDS=60

# Proxy behavior
PROXY_MODE=transparent
FAIL_OPEN=true
LOG_LEVEL=INFO
