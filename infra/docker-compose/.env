# Core auth secrets
CYBERARMOR_API_SECRET=change-me
CYBERARMOR_JWT_SECRET=change-me-jwt
POLICY_API_SECRET=change-me-policy
POLICY_API_KEY=change-me-policy
DETECTION_API_SECRET=change-me-detection
PROMPT_INJECTION_MODEL_BACKEND=transformer
PROMPT_INJECTION_MODEL_PATH=/models/prompt-injection-distilbert
PROMPT_INJECTION_MODEL_POSITIVE_LABEL_INDEX=1
PROMPT_INJECTION_ENSEMBLE_THRESHOLD=0.66
SEMANTIC_DLP_THRESHOLD=0.62
IDENTITY_API_SECRET=change-me-identity
SIEM_API_SECRET=change-me-siem
COMPLIANCE_API_SECRET=change-me-compliance
PROXY_AGENT_API_SECRET=change-me-proxy
RESPONSE_API_SECRET=change-me-response
TELEMETRY_API_KEY=change-me-siem
INTEGRATION_CONTROL_API_SECRET=change-me-integration-control
SECRETS_SERVICE_API_SECRET=change-me-secrets-service
OPENBAO_DEV_ROOT_TOKEN=openbao-dev-root-token-change-me
INTEGRATION_POLICY_BLOCK_HIGH_RISK_SCOPE=true
INTEGRATION_POLICY_BLOCK_UNOWNED=true
INTEGRATION_POLICY_BLOCK_STALE_ACTIVE=false
INTEGRATION_POLICY_STALE_DAYS=30

# Security mode toggles
# In production, set CYBERARMOR_ENFORCE_SECURE_SECRETS=true and provide strong secrets.
# For local development only, you can temporarily bypass strict checks.
CYBERARMOR_ENFORCE_SECURE_SECRETS=false
CYBERARMOR_ALLOW_INSECURE_DEFAULTS=true
CYBERARMOR_ENFORCE_MTLS=false
CYBERARMOR_TLS_CA_FILE=/etc/cyberarmor/tls/ca.crt
CYBERARMOR_TLS_CERT_FILE=/etc/cyberarmor/tls/tls.crt
CYBERARMOR_TLS_KEY_FILE=/etc/cyberarmor/tls/tls.key
CYBERARMOR_ENABLE_NATIVE_TLS_LISTENER=false
CYBERARMOR_REQUIRE_CLIENT_CERT=false
PROMPT_INJECTION_MODEL_THRESHOLD=0.62
PROMPT_INJECTION_RISK_BASE=0.32
PROMPT_INJECTION_RISK_MULTIPLIER=0.85
PROMPT_INJECTION_RISK_CAP=0.85
CYBERARMOR_PROMPTWARE_SESSION_ENABLED=true
PROMPTWARE_SESSION_WINDOW_SECONDS=1800
PROMPTWARE_SESSION_MAX_EVENTS=20
PROMPTWARE_CHAIN_WARN_THRESHOLD=0.55
PROMPTWARE_CHAIN_BLOCK_THRESHOLD=0.85
CYBERARMOR_ENABLE_LEGACY_PROMPT_REGEX=false
CYBERARMOR_PQC_BACKEND=secrets-service

# Database
DATABASE_URL=postgresql://cyberarmor:cyberarmor@postgres:5432/cyberarmor
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
OPA_HOST_PORT=8181
OPENBAO_HOST_PORT=8200
POLICY_HOST_PORT=8001
AGENT_IDENTITY_HOST_PORT=8008
AI_ROUTER_HOST_PORT=8009
AUDIT_HOST_PORT=8011
SECRETS_SERVICE_HOST_PORT=8013

# Service URLs
CONTROL_PLANE_URL=http://control-plane:8000
POLICY_SERVICE_URL=http://policy:8001
DETECTION_SERVICE_URL=http://detection:8002
AISR_RUNTIME_URL=http://runtime:8000
PROXY_AGENT_URL=http://proxy-agent:8010
TELEMETRY_ENDPOINT=http://siem-connector:8005/ingest
COMPLIANCE_URL=http://compliance:8006
INTEGRATION_CONTROL_URL=http://integration-control:8012
SECRETS_SERVICE_URL=http://secrets-service:8013
OPENBAO_ADDR=http://openbao:8200
OPENBAO_NAMESPACE=
OPENBAO_KV_MOUNT=cyberarmor-kv
OPENBAO_TRANSIT_MOUNT=cyberarmor-transit
OPENBAO_TIMEOUT_SECONDS=5
ROUTER_USE_SECRETS_SERVICE=true
ROUTER_REQUIRE_SECRETS_SERVICE=false
# Shared secret used by control-plane when calling integration-control APIs.
# Keep aligned with INTEGRATION_CONTROL_API_SECRET value.

# Public URL used in the proxy's block page link (host-mapped control-plane).
INCIDENT_VIEWER_BASE_URL=http://localhost:8000

# Admin dashboard email-code access gate.
# Set ADMIN_DASHBOARD_ALLOWED_EMAILS to a comma-separated allowlist before sharing
# the dashboard. If no SMTP settings are provided, login codes are written to the
# dashboard-auth container logs. For local-only testing, DEV_CODE_ECHO can show
# the code on the login page.
ADMIN_DASHBOARD_ALLOWED_EMAILS=pmkelly2@icloud.com
ADMIN_DASHBOARD_SESSION_SECRET=change-me-dashboard-session-secret
ADMIN_DASHBOARD_AUTH_DEV_CODE_ECHO=true
ADMIN_DASHBOARD_CODE_TTL_SECONDS=600
ADMIN_DASHBOARD_SESSION_TTL_SECONDS=28800
ADMIN_DASHBOARD_MAX_CODE_ATTEMPTS=5
ADMIN_DASHBOARD_COOKIE_SECURE=false
ADMIN_DASHBOARD_SMTP_HOST=
ADMIN_DASHBOARD_SMTP_PORT=587
ADMIN_DASHBOARD_SMTP_USER=
ADMIN_DASHBOARD_SMTP_PASSWORD=
ADMIN_DASHBOARD_SMTP_FROM=
ADMIN_DASHBOARD_SMTP_TLS=true

# Customer portal tenant-scoped email-code access gate.
# Codes are written to control-plane logs when SMTP is not configured. Keep
# CUSTOMER_PORTAL_AUTH_DEV_CODE_ECHO=false outside local-only testing.
CUSTOMER_PORTAL_HOST_PORT=3001
CUSTOMER_PORTAL_PUBLIC_URL=http://localhost:3001
CUSTOMER_PORTAL_SESSION_SECRET=change-me-customer-portal-session-secret
CUSTOMER_PORTAL_AUTH_DEV_CODE_ECHO=true
CUSTOMER_PORTAL_CODE_TTL_SECONDS=600
CUSTOMER_PORTAL_SESSION_TTL_SECONDS=28800
CUSTOMER_PORTAL_MAX_CODE_ATTEMPTS=5
CUSTOMER_PORTAL_COOKIE_SECURE=false
CUSTOMER_PORTAL_SMTP_HOST=
CUSTOMER_PORTAL_SMTP_PORT=587
CUSTOMER_PORTAL_SMTP_USER=
CUSTOMER_PORTAL_SMTP_PASSWORD=
CUSTOMER_PORTAL_SMTP_FROM=
CUSTOMER_PORTAL_SMTP_TLS=true

# Tenant/runtime defaults
TENANT_ID=default
DEFAULT_PROXY_RUNTIME_MODE=mitm
# JSON object map: {"tenant-a":"envoy","tenant-b":"mitm"}
TENANT_PROXY_MODES={}
TENANT_MODE_CACHE_TTL_SECONDS=60

# Proxy behavior
PROXY_MODE=transparent
FAIL_OPEN=true
LOG_LEVEL=INFO
